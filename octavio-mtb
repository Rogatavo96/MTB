<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Octavio Ramírez – MTB</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  :root{
    --green:#1D9E75;
    --green-light:#5DCAA5;
    --purple:#7F77DD;
    --purple-dark:#3C3489;
    --black:#0a0a0a;
    --gray:#1a1a1a;
    --gray2:#2a2a2a;
    --text:#f0f0f0;
    --muted:#888;
  }
  html{scroll-behavior:smooth;}
  body{background:var(--black);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;overflow-x:hidden;}

  /* NAV */
  nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1.2rem 4rem;background:rgba(10,10,10,0.85);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.05);}
  .nav-logo{font-size:1.1rem;font-weight:700;letter-spacing:2px;color:var(--green);}
  .nav-links{display:flex;gap:2rem;}
  .nav-links a{color:var(--muted);text-decoration:none;font-size:.85rem;letter-spacing:1px;transition:color .3s;}
  .nav-links a:hover{color:var(--green);}

  /* HERO */
  #hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:6rem 4rem 4rem;position:relative;overflow:hidden;}
  .hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%, rgba(29,158,117,0.08) 0%, transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(127,119,221,0.07) 0%, transparent 50%);pointer-events:none;}
  .hero-eyebrow{font-size:.75rem;letter-spacing:4px;color:var(--green);text-transform:uppercase;margin-bottom:1.5rem;opacity:0;transform:translateY(20px);animation:fadeUp .8s .2s forwards;}
  .hero-name{font-size:clamp(3.5rem,8vw,7rem);font-weight:800;line-height:1;letter-spacing:-2px;margin-bottom:2rem;opacity:0;transform:translateY(20px);animation:fadeUp .8s .4s forwards;}
  .hero-name span{color:var(--green);}
  .hero-questions{display:flex;flex-direction:column;gap:1.2rem;opacity:0;transform:translateY(20px);animation:fadeUp .8s .6s forwards;}
  .hero-q{display:flex;align-items:baseline;gap:1rem;}
  .hero-q .q{font-size:.8rem;letter-spacing:2px;color:var(--muted);width:160px;}
  .hero-q .a{font-size:1.4rem;font-weight:600;color:var(--text);}
  .hero-q .a.accent{color:var(--green);}
  .hero-scroll{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;opacity:0;animation:fadeUp .8s 1.2s forwards;}
  .scroll-line{width:1px;height:50px;background:linear-gradient(to bottom, var(--green), transparent);}
  .scroll-text{font-size:.65rem;letter-spacing:3px;color:var(--muted);}

  /* SECTIONS */
  section{padding:6rem 4rem;}
  .section-label{font-size:.7rem;letter-spacing:4px;color:var(--green);text-transform:uppercase;margin-bottom:1rem;}
  .section-title{font-size:clamp(2rem,4vw,3rem);font-weight:700;line-height:1.1;margin-bottom:3rem;}

  /* SOBRE MI */
  #sobre{background:var(--gray);}
  .sobre-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;}
  .sobre-text p{font-size:1.05rem;line-height:1.8;color:rgba(240,240,240,.75);margin-bottom:1.5rem;}
  .stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:2rem;}
  .stat{padding:1.2rem;border:1px solid rgba(255,255,255,0.07);border-radius:8px;background:rgba(255,255,255,0.02);}
  .stat .num{font-size:2rem;font-weight:700;color:var(--green);}
  .stat .lbl{font-size:.75rem;color:var(--muted);letter-spacing:1px;margin-top:.2rem;}
  .habilidades{display:flex;flex-direction:column;gap:.8rem;}
  .hab-item .hab-header{display:flex;justify-content:space-between;margin-bottom:.4rem;font-size:.85rem;}
  .hab-bar{height:2px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden;}
  .hab-fill{height:100%;background:linear-gradient(90deg,var(--purple),var(--green));border-radius:2px;width:0;transition:width 1.2s ease;}

  /* PROYECTOS */
  #proyectos{background:var(--black);}
  .gallery-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1px;background:rgba(255,255,255,0.05);}
  .gallery-card{background:var(--black);aspect-ratio:4/3;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.8rem;cursor:pointer;position:relative;overflow:hidden;transition:background .3s;}
  .gallery-card:hover{background:var(--gray2);}
  .gallery-card .icon{font-size:2.5rem;color:rgba(255,255,255,0.1);transition:color .3s;}
  .gallery-card:hover .icon{color:var(--green);}
  .gallery-card .card-label{font-size:.75rem;letter-spacing:2px;color:var(--muted);transition:color .3s;}
  .gallery-card:hover .card-label{color:var(--green);}
  .gallery-note{text-align:center;margin-top:2rem;font-size:.85rem;color:var(--muted);}

  /* CONTACTO */
  #contacto{background:var(--gray);text-align:center;}
  .contact-inner{max-width:600px;margin:0 auto;}
  .contact-inner p{color:rgba(240,240,240,.6);margin-bottom:3rem;font-size:1rem;line-height:1.8;}
  .contact-links{display:flex;justify-content:center;gap:1.5rem;flex-wrap:wrap;}
  .contact-link{display:flex;align-items:center;gap:.6rem;padding:.9rem 1.8rem;border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:var(--text);text-decoration:none;font-size:.85rem;letter-spacing:1px;transition:all .3s;}
  .contact-link:hover{border-color:var(--green);color:var(--green);}
  .contact-link svg{width:18px;height:18px;}

  /* FOOTER */
  footer{background:var(--black);padding:2rem 4rem;display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(255,255,255,0.05);}
  footer span{font-size:.75rem;color:var(--muted);}

  /* REVEAL */
  .reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease, transform .7s ease;}
  .reveal.visible{opacity:1;transform:none;}

  @keyframes fadeUp{to{opacity:1;transform:translateY(0);}}

  @media(max-width:768px){
    nav{padding:1rem 1.5rem;}
    .nav-links{gap:1rem;}
    #hero,section{padding:5rem 1.5rem 3rem;}
    .sobre-grid{grid-template-columns:1fr;}
    footer{flex-direction:column;gap:1rem;text-align:center;}
  }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">OR</div>
  <div class="nav-links">
    <a href="#sobre">Sobre mí</a>
    <a href="#proyectos">Galería</a>
    <a href="#contacto">Contacto</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg"></div>
  <p class="hero-eyebrow">Mountain Bike · Descenso Técnico</p>
  <h1 class="hero-name">Octavio<br><span>Ramírez</span></h1>
  <div class="hero-questions">
    <div class="hero-q">
      <span class="q">¿Dónde estás?</span>
      <span class="a accent">Aquí</span>
    </div>
    <div class="hero-q">
      <span class="q">¿Qué hora es?</span>
      <span class="a accent">Ahora</span>
    </div>
    <div class="hero-q">
      <span class="q">¿Qué eres?</span>
      <span class="a">Este momento</span>
    </div>
  </div>
  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span class="scroll-text">Scroll</span>
  </div>
</section>

<!-- SOBRE MÍ -->
<section id="sobre">
  <div class="reveal">
    <p class="section-label">Sobre mí</p>
    <h2 class="section-title">El rider detrás<br>de la bici</h2>
  </div>
  <div class="sobre-grid">
    <div class="sobre-text reveal">
      <p>Soy Octavio, tengo 30 años. El mountain bike no es solo un deporte para mí — es una forma de estar presente, de conectar con el terreno y con el momento.</p>
      <p>Practico MTB de manera constante y realizo descenso técnico a través de caminos rurales, buscando siempre la línea perfecta entre control y adrenalina.</p>
      <div class="stats">
        <div class="stat"><div class="num">30</div><div class="lbl">Años</div></div>
        <div class="stat"><div class="num">MTB</div><div class="lbl">Disciplina</div></div>
        <div class="stat"><div class="num">DH</div><div class="lbl">Descenso técnico</div></div>
        <div class="stat"><div class="num">🌿</div><div class="lbl">Caminos rurales</div></div>
      </div>
    </div>
    <div class="habilidades reveal">
      <div class="hab-item">
        <div class="hab-header"><span>Descenso técnico</span><span style="color:var(--green)">95%</span></div>
        <div class="hab-bar"><div class="hab-fill" data-width="95"></div></div>
      </div>
      <div class="hab-item">
        <div class="hab-header"><span>Control en terreno</span><span style="color:var(--green)">88%</span></div>
        <div class="hab-bar"><div class="hab-fill" data-width="88"></div></div>
      </div>
      <div class="hab-item">
        <div class="hab-header"><span>Resistencia</span><span style="color:var(--green)">82%</span></div>
        <div class="hab-bar"><div class="hab-fill" data-width="82"></div></div>
      </div>
      <div class="hab-item">
        <div class="hab-header"><span>Lectura de ruta</span><span style="color:var(--green)">90%</span></div>
        <div class="hab-bar"><div class="hab-fill" data-width="90"></div></div>
      </div>
    </div>
  </div>
</section>

<!-- PROYECTOS / GALERÍA -->
<section id="proyectos">
  <div class="reveal">
    <p class="section-label">Galería</p>
    <h2 class="section-title">Cada ruta<br>cuenta una historia</h2>
  </div>
  <div class="gallery-grid reveal">
    <div class="gallery-card"><div class="icon">🏔</div><div class="card-label">Próximamente</div></div>
    <div class="gallery-card"><div class="icon">🚵</div><div class="card-label">Próximamente</div></div>
    <div class="gallery-card"><div class="icon">🌲</div><div class="card-label">Próximamente</div></div>
    <div class="gallery-card"><div class="icon">📷</div><div class="card-label">Próximamente</div></div>
    <div class="gallery-card"><div class="icon">🛤</div><div class="card-label">Próximamente</div></div>
    <div class="gallery-card"><div class="icon">⛰</div><div class="card-label">Próximamente</div></div>
  </div>
  <p class="gallery-note reveal">Las fotografías y videos estarán disponibles próximamente.</p>
</section>

<!-- CONTACTO -->
<section id="contacto">
  <div class="contact-inner">
    <div class="reveal">
      <p class="section-label">Contacto</p>
      <h2 class="section-title">Hablemos</h2>
      <p>¿Quieres ver más de mis rutas, descensos y aventuras en MTB? Sígueme en Instagram para contenido exclusivo del trail.</p>
    </div>
    <div class="contact-links reveal">
      <a class="contact-link" href="https://www.instagram.com/rogatavo/" target="_blank">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg>
        @rogatavo
      </a>
    </div>
  </div>
</section>

<footer>
  <span>© 2026 Octavio Ramírez</span>
  <span style="color:var(--green);letter-spacing:2px;font-size:.7rem;">MTB · DESCENSO TÉCNICO</span>
</footer>

<script>
  const observer = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.classList.add('visible');
        if(e.target.querySelectorAll('.hab-fill').length){
          e.target.querySelectorAll('.hab-fill').forEach(bar=>{
            bar.style.width = bar.dataset.width + '%';
          });
        }
      }
    });
  },{threshold:.15});
  document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
</script>
</body>
</html>
